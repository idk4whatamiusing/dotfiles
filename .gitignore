# Nix build output
home-manager/result

# node_modules (managed by npm, not dotfiles)
coc/extensions/node_modules/

# Vim coc plugin is its own git repo
vim/pack/coc/start/coc.nvim

# Tmux plugins are external git repos
tmux/plugins/tpm
tmux/plugins/tmux-resurrect
tmux/plugins/tmux-continuum

# zsh runtime data (not dotfiles)
zsh/.zsh_history
zsh/.zcompdump*
zsh/.zsh_sessions/

# Generated by home-manager on rebuild — not tracked in repo
zsh/.zshrc
zsh/.zshenv
zsh/.zprofile
git/config

# opencode config (managed by app, not dotfiles repo)
opencode/
result
